# Required
ANTHROPIC_API_KEY=sk-ant-...

# MCP server URLs
PULSE_MCP_URL=http://localhost:8001/mcp
RELEASE_AGENT_MCP_URL=http://localhost:8002/mcp

# Google OAuth (Phase 2b.1 — ADR-005)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/
# Authorized redirect URI must include OAUTH_REDIRECT_URI value.
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Session signing key for the ephemeral OAuth dance cookie (Starlette SessionMiddleware).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be stable across server restarts in production — if not set, a random key
# is generated per process start (acceptable for dev; breaks OAuth dance on restart).
SESSION_SECRET_KEY=...

# Database path (Phase 2b.1 — ADR-007)
# Relative to the working directory (project root when running uvicorn from repo root).
# Use an absolute path in production to point to durable storage.
# Default: war-room.db (no need to set if default is acceptable)
DB_PATH=war-room.db

# Dev / CI override
# Set to true to disable OAuth and fall back to X-User-Id mock auth header.
# Required when GOOGLE_CLIENT_ID is not set and you need to use the API directly.
DISABLE_OAUTH=false
